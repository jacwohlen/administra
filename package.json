{
  "name": "administra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@carbon/charts-svelte": "^1.22.18",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@playwright/test": "^1.59.1",
    "@skeletonlabs/skeleton": "^4.14.0",
    "@skeletonlabs/skeleton-svelte": "^4.14.0",
    "@supabase/supabase-js": "^2.101.1",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "image-resize-compress": "^2.1.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "supabase": "^2.84.4",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "svelte-fa": "^4.0.4",
    "svelte-heatmap": "^1.0.2",
    "svelte-i18n": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0"
  }
}
